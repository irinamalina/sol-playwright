{
  "name": "solstice-solar-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright end-to-end and API automation for the Solstice Solar demo site",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:chromium": "playwright test --project=chromium",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=chromium --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --project=chromium --debug",
    "test:ci": "SKIP_WEB_SERVER=1 playwright test",
    "report": "playwright show-report",
    "test:reset-db": "node scripts/reset-test-data.js",
    "test:triage": "node scripts/triage-results.js",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.2"
  }
}
