# Copy to .env and adjust if the app runs on non-default ports.
BASE_URL=http://localhost:5173
API_URL=http://localhost:4000/api
CLIENT_PORT=5173
SERVER_PORT=4000

# Set to 1 to skip Playwright's built-in webServer auto-start.
# Use this when an agent/orchestrator already manages the client & server
# processes itself (e.g. a long-running CI environment or scheduled agent).
SKIP_WEB_SERVER=
